<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ورشة أبو إلياس للتمديدات الصحية</title>
    <!-- تضمين مكتبة Tailwind CSS للتصميم الاحترافي -->
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <!-- تضمين أيقونات FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- خطوط جوجل (صناعة الخطوط العربية) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Cairo', sans-serif;
        }
    </style>
</head>
<body class="bg-gray-50 text-gray-800">

    <!-- القائمة العلوية (Navbar) -->
    <header class="bg-white shadow-md sticky top-0 z-50">
        <div class="container mx-auto px-6 py-4 flex justify-between items-center">
            <div class="flex items-center space-x-reverse space-x-2">
                <i class="fa-solid font-bold fa-faucet-drip text-blue-600 text-3xl"></i>
                <span class="text-xl font-bold text-blue-900">ورشة أبو إلياس</span>
            </div>
            <nav class="hidden md:flex space-x-reverse space-x-8 font-medium">
                <a href="#home" class="text-blue-600 hover:text-blue-800 transition">الرئيسية</a>
                <a href="#services" class="text-gray-600 hover:text-blue-600 transition">خدماتنا</a>
                <a href="#gallery" class="text-gray-600 hover:text-blue-600 transition">أعمالنا</a>
                <a href="#contact" class="text-gray-600 hover:text-blue-600 transition">اتصل بنا</a>
            </nav>
            <a href="tel:0959602410" class="bg-blue-600 text-white px-5 py-2 rounded-full font-bold hover:bg-blue-700 transition flex items-center gap-2 shadow-lg shadow-blue-200">
                <i class="fa-solid fa-phone-flip animate-pulse"></i>
                <span>إتصل الآن</span>
            </a>
        </div>
    </header>

    <!-- القسم الرئيسي (Hero Section) -->
    <section id="home" class="relative bg-gradient-to-r from-blue-900 to-blue-700 text-white py-24 md:py-32 overflow-hidden">
        <div class="absolute inset-0 opacity-20">
            <img src="https://images.unsplash.com/photo-1584622650111-993a426fbf0a?auto=format&fit=crop&q=80&w=1200" alt="Plumbing background" class="w-full h-full object-cover">
        </div>
        <div class="container mx-auto px-6 relative z-10 text-center md:text-right flex flex-col md:flex-row items-center justify-between gap-12">
            <div class="md:w-1/2 space-y-6">
                <span class="bg-blue-500/30 text-blue-200 px-4 py-1.5 rounded-full text-sm font-semibold tracking-wide">خبرة واحترافية عالية</span>
                <h1 class="text-4xl md:text-5xl font-bold leading-tight">ورشة أبو إلياس <br><span class="text-blue-300">للتمديدات الصحية والصيانة العامة</span></h1>
                <p class="text-lg text-blue-100 max-w-xl">
                    نقدم أفضل خدمات التأسيس والصيانة للتمديدات الصحية، تركيب المغاسل، الشاورات، وتجهيز الشبكات بأحدث المعدات وأعلى جودة إتقان.
                </p>
                <div class="flex flex-wrap justify-center md:justify-start gap-4 pt-4">
                    <a href="tel:0959602410" class="bg-emerald-500 hover:bg-emerald-600 text-white font-bold px-8 py-4 rounded-xl shadow-lg transition flex items-center gap-3 text-lg">
                        <i class="fa-solid fa-phone"></i> 0959602410
                    </a>
                    <a href="#services" class="bg-white/10 hover:bg-white/20 text-white border border-white/30 font-bold px-8 py-4 rounded-xl transition">
                        اكتشف خدماتنا
                    </a>
                </div>
            </div>
            <div class="md:w-1/2 w-full max-w-md md:max-w-none">
                <img src="https://images.unsplash.com/photo-1621905251189-08b45d6a269e?auto=format&fit=crop&q=80&w=800" alt="Plumbing Work" class="rounded-2xl shadow-2xl border-4 border-white/10 object-cover w-full h-[350px]">
            </div>
        </div>
    </section>

    <!-- قسم المميزات السريعة -->
    <section class="container mx-auto px-6 -mt-12 relative z-20">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="bg-white p-6 rounded-xl shadow-xl flex items-center gap-4 border-b-4 border-blue-600">
                <div class="bg-blue-100 p-4 rounded-lg text-blue-600 text-2xl"><i class="fa-solid fa-clock"></i></div>
                <div>
                    <h3 class="font-bold text-lg text-blue-950">سرعة في التلبية</h3>
                    <p class="text-sm text-gray-500">نصلك في أسرع وقت لحل المشاكل طارئة.</p>
                </div>
            </div>
            <div class="bg-white p-6 rounded-xl shadow-xl flex items-center gap-4 border-b-4 border-emerald-500">
                <div class="bg-emerald-100 p-4 rounded-lg text-emerald-600 text-2xl"><i class="fa-solid fa-shield-halved"></i></div>
                <div>
                    <h3 class="font-bold text-lg text-blue-950">جودة مضمونة</h3>
                    <p class="text-sm text-gray-500">مواد أصلية عمل متقن يعيش طويلاً.</p>
                </div>
            </div>
            <div class="bg-white p-6 rounded-xl shadow-xl flex items-center gap-4 border-b-4 border-amber-500">
                <div class="bg-amber-100 p-4 rounded-lg text-amber-600 text-2xl"><i class="fa-solid fa-hand-holding-dollar"></i></div>
                <div>
                    <h3 class="font-bold text-lg text-blue-950">أسعار مدروسة</h3>
                    <p class="text-sm text-gray-500">أفضل تكلفة مقابل أعلى جودة خدمة بالمنطقة.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- قسم الخدمات (Services) -->
    <section id="services" class="py-20 bg-gray-50">
        <div class="container mx-auto px-6">
            <div class="text-center max-w-xl mx-auto mb-16">
                <h2 class="text-3xl font-bold text-blue-950 mb-4">ماذا نقدم في ورشة أبو إلياس؟</h2>
                <div class="h-1 w-20 bg-blue-600 mx-auto rounded-full"></div>
                <p class="text-gray-600 mt-4">نغطي كافة أعمال التمديدات الصحية والصيانة السريعة والتأسيس للمباني والمنشآت.</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <!-- خدمة 1 -->
                <div class="bg-white p-8 rounded-2xl shadow-sm hover:shadow-xl transition duration-300 border border-gray-100 group">
                    <div class="text-blue-600 text-4xl mb-4 group-hover:scale-110 transition duration-300"><i class="fa-solid fa-pipes"></i><i class="fa-solid fa-screwdriver-wrench"></i></div>
                    <h3 class="text-xl font-bold text-blue-950 mb-3">تأسيس شبكات المياه والصرف</h3>
                    <p class="text-gray-600 text-sm leading-relaxed">تمديد الأنابيب الحرارية وشبكات الصرف الصحي للمباني قيد الإنشاء بأعلى معايير الكفاءة ومنع التسريب تماماً.</p>
                </div>
                <!-- خدمة 2 -->
                <div class="bg-white p-8 rounded-2xl shadow-sm hover:shadow-xl transition duration-300 border border-gray-100 group">
                    <div class="text-blue-600 text-4xl mb-4 group-hover:scale-110 transition duration-300"><i class="fa-solid fa-shower"></i></div>
                    <h3 class="text-xl font-bold text-blue-950 mb-3">تركيب مغاسل وشاورات وأطقم صحية</h3>
                    <p class="text-gray-600 text-sm leading-relaxed">تركيب بدقة وعناية للمغاسل، خلاطات المياه، الشاورات الحديثة، وكافة إكسسوارات الحمامات والمطابخ الفاخرة.</p>
                </div>
                <!-- خدمة 3 -->
                <div class="bg-white p-8 rounded-2xl shadow-sm hover:shadow-xl transition duration-300 border border-gray-100 group">
                    <div class="text-blue-600 text-4xl mb-4 group-hover:scale-110 transition duration-300"><i class="fa-solid fa-droplet-slash"></i></div>
                    <h3 class="text-xl font-bold text-blue-950 mb-3">صيانة الأعطال وكشف التسريبات</h3>
                    <p class="text-gray-600 text-sm leading-relaxed">إصلاح سريع لخلاطات المياه المكسورة، انسداد المجاري، وتغيير القطع التالفة بقطع غيار أصلية ومكفولة.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- معرض صور ملفت للأنظار (Gallery) -->
    <section id="gallery" class="py-20 bg-white">
        <div class="container mx-auto px-6">
            <div class="text-center max-w-xl mx-auto mb-16">
                <h2 class="text-3xl font-bold text-blue-950 mb-4">معرض أعمالنا وجودة تشطيباتنا</h2>
                <div class="h-1 w-20 bg-blue-600 mx-auto rounded-full"></div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
                <div class="overflow-hidden rounded-xl shadow-md group relative">
                    <img src="https://images.unsplash.com/photo-1504148455328-c376907d081c?auto=format&fit=crop&q=80&w=600" alt="تركيب تمديدات" class="w-full h-64 object-cover group-hover:scale-105 transition duration-500">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent opacity-0 group-hover:opacity-100 transition duration-300 flex items-end p-4">
                        <p class="text-white font-bold">دقة وتناسق في توزيع التمديدات</p>
                    </div>
                </div>
                <div class="overflow-hidden rounded-xl shadow-md group relative">
                    <img src="https://images.unsplash.com/photo-1600566752355-35792bedcfea?auto=format&fit=crop&q=80&w=600" alt="تركيب شاورات" class="w-full h-64 object-cover group-hover:scale-105 transition duration-500">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent opacity-0 group-hover:opacity-100 transition duration-300 flex items-end p-4">
                        <p class="text-white font-bold">تركيب أطقم حمامات وشاورات مودرن</p>
                    </div>
                </div>
                <div class="overflow-hidden rounded-xl shadow-md group relative">
                    <img src="https://images.unsplash.com/photo-1585338107529-13afc5f02586?auto=format&fit=crop&q=80&w=600" alt="صيانة أدوات صحية" class="w-full h-64 object-cover group-hover:scale-105 transition duration-500">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent opacity-0 group-hover:opacity-100 transition duration-300 flex items-end p-4">
                        <p class="text-white font-bold">تجهيز خلاطات وإكسسوارات عالية الجودة</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- قسم اتصل بنا السريع والتواصل (Contact) -->
    <section id="contact" class="py-16 bg-blue-50">
        <div class="container mx-auto px-6 text-center max-w-2xl">
            <div class="bg-white p-8 md:p-12 rounded-3xl shadow-xl border border-blue-100">
                <i class="fa-solid fa-headset text-blue-600 text-5xl mb-4"></i>
                <h2 class="text-2xl md:text-3xl font-bold text-blue-950 mb-2">هل تحتاج إلى سباك محترف فوراً؟</h2>
                <p class="text-gray-600 mb-8">أبو إلياس في خدمتكم دائماً. اتصل بنا الآن ولا تتردد، نصلك أينما كنت وبأسرع وقت.</p>
                
                <div class="bg-blue-900 text-white rounded-2xl p-6 flex flex-col sm:flex-row items-center justify-between gap-4 shadow-inner">
                    <div class="text-right sm:text-right text-center">
                        <p class="text-xs text-blue-200 uppercase tracking-wider font-semibold">رقم الهاتف المباشر</p>
                        <p class="text-2xl font-bold tracking-wide mt-1">0959602410</p>
                    </div>
                    <a href="tel:0959602410" class="w-full sm:w-auto bg-emerald-500 hover:bg-emerald-600 text-white font-bold px-6 py-3.5 rounded-xl transition flex items-center justify-center gap-2 text-lg shadow-md">
                        <i class="fa-solid fa-phone-volume"></i>
                        اضغط للاتصال الآن
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- الفوتر (Footer) -->
    <footer class="bg-blue-950 text-blue-200 py-8 border-t border-blue-900 text-center">
        <div class="container mx-auto px-6">
            <p class="text-sm">&copy; 2026 ورشة أبو إلياس للتمديدات الصحية. جميع الحقوق محفوظة.</p>
        </div>
    </footer>

</body>
</html>
